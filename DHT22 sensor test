import time
import board
import adafruit_dht

# Initialize the sensor on GPIO4 (physical pin 7)
dht = adafruit_dht.DHT22(board.D4)

print("Starting DHT22 test... Press CTRL+C to stop")

while True:
    try:
        temperature_c = dht.temperature
        temperature_f = temperature_c * (9 / 5) + 32
        humidity = dht.humidity

        print(f"Temp: {temperature_c:.1f}°C / {temperature_f:.1f}°F   Humidity: {humidity:.1f}%")

    except RuntimeError as error:
        # DHT sensors occasionally fail to read - this is normal, just retry
        print(f"Reading failed: {error.args[0]}")

    except Exception as error:
        dht.exit()
        raise error

    time.sleep(2)  # DHT22 needs at least 2 seconds between reads
