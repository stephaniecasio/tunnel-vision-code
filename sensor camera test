#!/usr/bin/env python3
"""
capture_cycle.py

One full capture cycle (LED control removed):
  1. Record a 30-second video from the Arducam IMX219 camera
  2. Read DHT22 temperature/humidity (GPIO4 / physical pin 7)
  3. Log timestamp + sensor readings + video filename to CSV

Requirements:
  pip3 install --break-system-packages picamera2
  pip3 install --break-system-packages adafruit-circuitpython-dht adafruit-blinka
  pip3 install --break-system-packages RPi.GPIO
"""

import csv
import os
import time
from datetime import datetime

import RPi.GPIO as GPIO
import adafruit_dht
import board

from picamera2 import Picamera2
from picamera2.encoders import H264Encoder
from picamera2.outputs import FfmpegOutput


# ---------------- Configuration ----------------

DHT_PIN = board.D4       # BCM GPIO4 = physical pin 7

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))

VIDEO_DIR = os.path.join(
    SCRIPT_DIR,
    "captures",
    "video"
)

LOG_DIR = os.path.join(
    SCRIPT_DIR,
    "captures",
    "logs"
)

LOG_FILE = os.path.join(
    LOG_DIR,
    "sensor_log.csv"
)

RECORD_SECONDS = 30


# ---------------- Setup ----------------

os.makedirs(VIDEO_DIR, exist_ok=True)
os.makedirs(LOG_DIR, exist_ok=True)

GPIO.setmode(GPIO.BCM)

dht_device = adafruit_dht.DHT22(DHT_PIN)


# ---------------- Camera ----------------

def record_video(filepath, seconds):
    """
    Records video from Picamera2.
    Output is MP4 through FFmpeg.
    """

    picam2 = Picamera2(camera_num=0)

    video_config = picam2.create_video_configuration(
        main={
            "size": (1280, 720)
        }
    )

    picam2.configure(video_config)

    encoder = H264Encoder(
        bitrate=10000000
    )

    output = FfmpegOutput(
        filepath
    )

    try:
        print("Starting camera...")

        picam2.start()

        # Allow sensor exposure/focus settings to stabilize
        time.sleep(2)

        print("Starting recording...")

        picam2.start_recording(
            encoder,
            output
        )

        time.sleep(seconds)

        picam2.stop_recording()

        print("Recording complete")

    finally:
        picam2.close()


# ---------------- DHT22 ----------------

def read_dht22(retries=5, delay=2):

    for attempt in range(retries):

        try:
            temperature_c = dht_device.temperature
            humidity = dht_device.humidity

            if (
                temperature_c is not None
                and humidity is not None
            ):
                return (
                    round(temperature_c, 2),
                    round(humidity, 2)
                )

        except RuntimeError as e:
            print(
                f"DHT22 attempt {attempt + 1} failed: {e}"
            )

        time.sleep(delay)

    return None, None


# ---------------- Logging ----------------

def log_reading(
    timestamp,
    temp_c,
    humidity,
    video_filename
):

    file_exists = os.path.isfile(
        LOG_FILE
    )

    with open(
        LOG_FILE,
        "a",
        newline=""
    ) as f:

        writer = csv.writer(f)

        if not file_exists:
            writer.writerow(
                [
                    "timestamp",
                    "temperature_c",
                    "humidity_percent",
                    "video_file"
                ]
            )

        writer.writerow(
            [
                timestamp,
                temp_c,
                humidity,
                video_filename
            ]
        )


# ---------------- Main Cycle ----------------

def run_capture_cycle():

    start_time = datetime.now()

    ts_str = start_time.strftime(
        "%Y%m%d_%H%M%S"
    )

    video_filename = (
        f"video_{ts_str}.mp4"
    )

    video_path = os.path.join(
        VIDEO_DIR,
        video_filename
    )


    print(
        f"[{start_time}] Starting capture cycle"
    )


    print(
        f"Recording {RECORD_SECONDS}s video -> {video_path}"
    )


    record_video(
        video_path,
        RECORD_SECONDS
    )


    print(
        "Reading DHT22"
    )


    temp_c, humidity = read_dht22()


    if temp_c is None:
        print(
            "WARNING: DHT22 read failed"
        )


    log_time = datetime.now().isoformat()


    log_reading(
        log_time,
        temp_c,
        humidity,
        video_filename
    )


    print(
        f"Logged: temp={temp_c}C humidity={humidity}% video={video_filename}"
    )


# ---------------- Run ----------------

if __name__ == "__main__":

    try:
        run_capture_cycle()

    finally:

        GPIO.cleanup()

        try:
            dht_device.exit()

        except Exception:
            pass
