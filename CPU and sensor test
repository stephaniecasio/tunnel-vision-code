#!/usr/bin/env python3
"""
Raspberry Pi enclosure thermal test.

Logs:
- Raspberry Pi CPU temperature
- DHT22 temperature
- DHT22 humidity

Stops when CPU reaches 55°C or after test duration.

Run this while your normal rover software is running.
"""

import csv
import time
import subprocess
from datetime import datetime

import board
import adafruit_dht


# -----------------------------
# Settings
# -----------------------------

LOG_FILE = "rover_thermal_test.csv"

TEST_DURATION = 1800     # seconds (30 minutes)
INTERVAL = 2             # seconds between samples

MAX_CPU_TEMP = 55.0      # stop test at this CPU temperature


# -----------------------------
# DHT22 setup
# -----------------------------

dht = adafruit_dht.DHT22(
    board.D4,
    use_pulseio=False
)


# -----------------------------
# CPU temperature function
# -----------------------------

def read_cpu_temp_c():
    """Read Raspberry Pi CPU temperature."""

    try:
        output = subprocess.check_output(
            ["vcgencmd", "measure_temp"],
            text=True
        )

        return float(
            output.split("=")[1].split("'")[0]
        )

    except Exception:

        try:
            with open(
                "/sys/class/thermal/thermal_zone0/temp"
            ) as f:
                return int(f.read()) / 1000.0

        except Exception:
            return None



# -----------------------------
# Main logging loop
# -----------------------------

start = time.time()

print("Starting rover thermal test")
print(f"Stop temperature: {MAX_CPU_TEMP}°C")
print(f"Maximum duration: {TEST_DURATION/60:.1f} minutes\n")


try:

    with open(LOG_FILE, "w", newline="") as file:

        writer = csv.writer(file)

        writer.writerow([
            "timestamp",
            "elapsed_s",
            "cpu_temp_c",
            "dht_temp_c",
            "humidity_pct"
        ])


        while True:

            elapsed = time.time() - start


            # Stop after time limit
            if elapsed >= TEST_DURATION:
                print("\nMaximum test duration reached.")
                break


            # Read CPU temperature
            cpu_temp = read_cpu_temp_c()


            # Stop if CPU gets too hot
            if (
                cpu_temp is not None
                and cpu_temp >= MAX_CPU_TEMP
            ):

                print(
                    f"\nCPU reached "
                    f"{cpu_temp:.1f}°C."
                )

                print(
                    "Stopping thermal test."
                )

                break



            # Read DHT22
            try:

                dht_temp = dht.temperature
                humidity = dht.humidity

            except RuntimeError:

                dht_temp = None
                humidity = None



            timestamp = datetime.now().strftime(
                "%H:%M:%S"
            )


            # Save data
            writer.writerow([
                timestamp,
                round(elapsed, 1),
                cpu_temp,
                dht_temp,
                humidity
            ])

            file.flush()



            print(
                f"{timestamp} | "
                f"CPU: {cpu_temp:.1f}°C | "
                f"DHT22: {dht_temp}°C | "
                f"Humidity: {humidity}%"
            )


            time.sleep(INTERVAL)



except KeyboardInterrupt:

    print("\nStopped manually.")



finally:

    try:
        dht.exit()

    except Exception:
        pass



print(
    f"\nSaved data to {LOG_FILE}"
)
